# ============================================================================
# PickFit — environment template
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in. README §6 has the full reference.
# Anything sensitive (OPENAI_API_KEY, DB_PASSWORD) MUST NOT be committed.
# ============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=local                                  # `production` flips Secure cookies on
APP_URL=http://127.0.0.1:8000                  # used only for meta / log lines
APP_TIMEZONE=Asia/Seoul

# --- Sessions / cookies ------------------------------------------------------
SESSION_NAME=pickfit_session
SESSION_SECURE=false                           # forced true when APP_ENV != local

# --- MySQL connection --------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pickfit
DB_USERNAME=root
DB_PASSWORD=

# --- OpenAI Responses API ----------------------------------------------------
# Leave OPENAI_API_KEY blank to skip OpenAI entirely — recommendations fall
# back to the deterministic engine and the user does not see any difference.
# Both API_KEY and MODEL must be present to enable the OpenAI branch.
OPENAI_API_KEY=
OPENAI_MODEL=                                  # e.g. gpt-4o-mini

# Bumped 45 → 60 in Task B-4 because gpt-4o-mini occasionally takes 40-50s
# under load. Frontend timeout (recommendations.js) is 75s to leave headroom.
OPENAI_TIMEOUT_SECONDS=60

# When true, CrawlerService routes Playwright results through OpenAI to fill
# fit / material / season / tags. Keep false unless you have explicit budget
# for per-URL extraction calls AND have re-verified the Day 9 Hotfix stored-XSS
# defenses (escape.js + ProductRepository::sanitizeText) before turning on.
OPENAI_EXTRACTION_ENABLED=false

# --- Playwright crawler ------------------------------------------------------
NODE_BINARY=node                               # absolute path if `node` is not on PATH
PLAYWRIGHT_CRAWLER_PATH=crawler/playwright-crawl.js
CRAWL_TIMEOUT_SECONDS=45                       # navigation timeout per URL
CRAWL_ARTIFACT_ROOT=storage/crawls             # screenshots / raw payloads
CRAWL_MAX_TEXT_CHARS=20000
CRAWL_MAX_IMAGE_COUNT=12

# --- Rate limiters (file-based, per IP per hour) -----------------------------
RATE_LIMIT_AUTH_PER_HOUR=20
RATE_LIMIT_CRAWL_PER_HOUR=10
RATE_LIMIT_RECOMMEND_PER_HOUR=20
