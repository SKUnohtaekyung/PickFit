{
  "scripts": {
    "dev": "php -S 127.0.0.1:8000 -t public public/index.php",
    "tailwind:watch": "tailwindcss -i ./public/css/input.css -o ./public/css/app.css --watch",
    "tailwind:build": "tailwindcss -i ./public/css/input.css -o ./public/css/app.css --minify",
    "build": "npm run tailwind:build",
    "security:scan": "node scripts/security-scan.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "http-server": "^14.1.1",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  }
}
